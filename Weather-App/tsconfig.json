{
  "compilerOptions": {
    "strict": true,
    "types": ["jest"],
    "esModuleInterop": true,
    "jsx": "react-native",
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "*"
      ]
    }
  },
  "include": [
    "**/*.ts",
